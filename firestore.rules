rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - id: string (required)
    //   - categoryId: string (required)
    //   - name: string (required)
    //   - imageUrl: string (optional)
    //   - location: string (optional)
    //   - characteristics: list (optional)
    //
    // Collection: categories
    // Document ID: {categoryId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - parentId: string (optional)
    //   - subcategories: list (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalStringLength(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
        (request.resource.data[field] is string &&
         request.resource.data[field].size() >= minLen &&
         request.resource.data[field].size() <= maxLen);
    }

    function isValidProduct(data) {
      return hasRequiredFields(['id', 'categoryId', 'name']) &&
             isValidStringLength('id', 1, 100) &&
             isValidStringLength('categoryId', 1, 100) &&
             isValidStringLength('name', 1, 500) &&
             isValidOptionalStringLength('imageUrl', 0, 2000) &&
             isValidOptionalStringLength('location', 0, 500) &&
             (!( 'characteristics' in data ) || data.characteristics is list);
    }

    function isValidCategory(data) {
      return hasRequiredFields(['id', 'name']) &&
             isValidStringLength('id', 1, 100) &&
             isValidStringLength('name', 1, 500) &&
             (!( 'parentId' in data ) || data.parentId == null || (data.parentId is string && data.parentId.size() <= 100)) &&
             (!( 'subcategories' in data ) || data.subcategories is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidProduct(request.resource.data);
      allow update: if isAuthenticated() && isValidProduct(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidCategory(request.resource.data);
      allow update: if isAuthenticated() && isValidCategory(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /settings/admin {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
